	email = edwardbo123@gmail.com
	name = Nedwardo
[core]
	editor = nvim
[init]
	defaultBranch = main
[pull]
	rebase = true
[maintenance]
	auto = true
	strategy = incremental
[alias]
	chekcout = checkout
[merge]
	tool = nvimdiff
[mergetool "nvimdiff"]
	cmd = nvim -d $LOCAL $BASE $REMOTE $MERGED -c \"$wincmd w\" -c \"wincmd J\"
